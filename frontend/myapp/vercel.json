{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/myapp/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "env": {
    "GATEWAY_API_URL": "https://your-backend-api-url.com"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}